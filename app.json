{
  "expo": {
    "name": "EcoChain Link",
    "slug": "ecochain-link",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecochainlink",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#ECE6D3",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "EcoChain Link uses your camera to scan product barcodes on-device. Nothing is recorded or uploaded.",
        "NSLocationWhenInUseUsageDescription": "EcoChain Link uses your location to find and sort nearby recyclers and collection points by distance."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#152D26",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA", "ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#152D26",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "EcoChain Link uses your camera to scan product barcodes on-device. Nothing is recorded or uploaded."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EcoChain Link uses your location to find and sort nearby recyclers by distance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
