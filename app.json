{
  "expo": {
    "name": "EcoChain Link",
    "slug": "ecochain-link",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ecochain-icon.png",
    "scheme": "ecochainlink",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F2E3BC",
    "splash": {
      "image": "./assets/images/ecochain-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2E3BC"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#F2E3BC"
      },
      "splash": {
        "image": "./assets/images/ecochain-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#F2E3BC"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.ayushsharma1908.ecochainlink",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayushsharma1908.ecochainlink",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "EcoChain Link uses your camera to scan product barcodes on-device. Nothing is recorded or uploaded.",
        "NSLocationWhenInUseUsageDescription": "EcoChain Link uses your location to find and sort nearby recyclers and collection points by distance."
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/ecochain-icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ecochain-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F2E3BC"
        }
      ],

      [
        "expo-camera",
        {
          "cameraPermission": "EcoChain Link uses your camera to scan product barcodes on-device. Nothing is recorded or uploaded."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EcoChain Link uses your location to find and sort nearby recyclers by distance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2791456c-85a4-490e-8a70-348f934294e7"
      }
    }
  }
}
